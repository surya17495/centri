{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CENTRI",
  "version": "0.1.0",
  "identifier": "ai.centri.shell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CENTRI",
        "width": 960,
        "height": 720,
        "minWidth": 480,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {
    "global-shortcut": {}
  }
}
