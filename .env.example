# CENTRI configuration — copy to .env and fill in. BYOK: bring your own keys.
# Nothing here is a real secret; .env itself is gitignored.
#
# Docker (docker compose up -d): this file is read by docker-compose.yml at
# runtime — keys live here, never baked into the image. The compose file
# overrides CENTRI_CORE_HOST/PORT and CENTRI_DB_PATH for the container (binds
# 0.0.0.0 inside the container, state on a named volume), so you mainly fill in
# the model gateway / provider keys below. See docs/DEPLOY.md.

# --- Server ---
CENTRI_CORE_HOST=127.0.0.1
CENTRI_CORE_PORT=8760
CENTRI_CORE_TOKEN=change-me
# Bearer token required on all REST routes except /health (and ?token= on WS).
# Empty = auth disabled (local dev only). SET THIS before exposing the VM port.
CENTRI_AUTH_TOKEN=

# --- Database ---
CENTRI_DB_PATH=~/.centri/state.db

# --- Model gateway (LiteLLM proxy or direct provider) ---
LITELLM_BASE_URL=
LITELLM_API_KEY=

# --- Model role names (resolved by LiteLLM / your provider) ---
MODEL_INTENT=meta-llama/Llama-3.3-70B-Instruct
MODEL_FAST_REPLY=meta-llama/Llama-3.3-70B-Instruct
MODEL_REASONING=deepseek-ai/DeepSeek-V3
MODEL_NARRATION=meta-llama/Llama-3.3-70B-Instruct
MODEL_SUMMARIZATION=meta-llama/Llama-3.3-70B-Instruct
MODEL_VISION=
MODEL_EMBEDDINGS=

# --- Nebius (OpenAI-compatible backend, used through LiteLLM) ---
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1

# --- Embeddings (Unit 2: semantic recall) ---
# OFF by default (NullEmbeddingProvider → no vectors, offline-green tests). Two
# ways to turn it on; both are explicit, nothing turns on by accident.
#
# (a) Local pinned model via fastembed — preferred, no network at read OR write
#     once the model is cached. Requires the optional `fastembed` package.
# CENTRI_EMBEDDING_LOCAL_MODEL=BAAI/bge-small-en-v1.5
#
# (b) Network model via the OpenAI-compatible LiteLLM route (provider-agnostic;
#     Nebius Token Factory shown). Set the embedding model + enable the route,
#     and point the LiteLLM transport at your base URL + key. The model name is
#     pinned into the brief's embedding stamp.
# CENTRI_EMBEDDING_ENABLED=true
# CENTRI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# LITELLM_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# LITELLM_API_KEY=your-nebius-token-factory-key
#
# Embeddings only MOVE a score when the similarity weight is positive. Turning it
# on is a deliberate one-line change that bumps POLICY_VERSION → "3c.1-embed"
# (its own golden); leave it 0.0 to keep the pre-embedding briefs byte-identical.
# CENTRI_CURATION_W_EMBEDDING_SIMILARITY=0.3
#
# After enabling, backfill vectors for nodes written before embeddings were on:
#   centri memory rebuild --embed        (re-derives the graph from the spine)
#   POST /memory/embeddings/backfill     (idempotent in-place backfill)

# --- OpenAI (direct provider path when not using a LiteLLM proxy) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Letta (optional semantic memory backend; CENTRI runs without it) ---
CENTRI_LETTA_URL=
CENTRI_LETTA_API_KEY=
CENTRI_LETTA_AGENT_ID=centri-main

# --- centri-bench LLM judge (python -m centri.bench.run --judge) ---
# Any non-empty api key works against an upstream-auth relay; never commit a real key.
CENTRI_JUDGE_BASE_URL=http://127.0.0.1:8901/v1
CENTRI_JUDGE_MODEL=moonshotai/Kimi-K2.6
CENTRI_JUDGE_API_KEY=sandbox

# --- Hands (coding agents) ---
# Every hand is an ACP agent identified by a launch command. The canonical
# default coding hand is OpenCode-over-ACP ("acp" with CENTRI_ACP_COMMAND below);
# "opencode" is the native-subprocess degraded fallback. Other agents
# (Cursor, Claude Code, ...) are config entries — set CENTRI_ACP_COMMAND, no code.
CENTRI_ENABLED_HANDS=acp,opencode
CENTRI_HAND_PRIORITY=acp,opencode
CENTRI_ACP_COMMAND=opencode acp
OPENCODE_CLI=opencode
# Optional: tail an external opencode.db into the spine each scheduler tick
# (3b.3 ingestion adapter). Empty = no ambient tail; POST /ingest/opencode
# still works for one-shot ingests.
CENTRI_OPENCODE_INGEST_DB=
# Memory bootstrap (3b.4): discovery + one-time import of existing coding-agent
# histories so a fresh install starts with complete memory. Discovery probes
# well-known default paths per platform; these override/extend the probe set per
# agent (comma-separated) for stores in unusual locations. Bootstrap = first
# tick (ingestion is HWM-based), so GET /ingest/discover then POST /ingest/bootstrap.
CENTRI_INGEST_OPENCODE_PATHS=
CENTRI_INGEST_CLAUDE_CODE_PATHS=
CENTRI_INGEST_CURSOR_PATHS=
# Comma-separated agents to skip entirely (privacy / opt-out): opencode,claude_code,cursor
CENTRI_INGEST_DISABLED_AGENTS=

# --- Session-start push briefing ---
# On session start CENTRI builds the deterministic, LLM-free "what changed /
# what's blocked / what's next" brief and surfaces it unprompted (brief.session_start
# spine event + first-turn context). Cheap (no model call), so default on. Set
# to 0/false to disable.
CENTRI_SESSION_BRIEF=1

# --- LLM consolidation tier (proposal contract) ---
# A SECOND consolidation tier processes events with NO deterministic synthesis
# hint (raw stdout, transcripts): the LLM proposes typed ops and a deterministic
# gatekeeper applies/rejects them with provenance receipts. The deterministic hint
# path stays authoritative and untouched. Honest-unavailable: with no base_url +
# model below the tier does nothing. Generic OpenAI-compatible (Nebius Token
# Factory shown); the key is injected at runtime by the orchestrator — never commit
# a real key. Batch fires when the unhinted backlog reaches the batch size (or a
# staleness bound is exceeded). Live smoke check: scripts/live_consolidation_check.py
# CENTRI_CONSOLIDATION_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# CENTRI_CONSOLIDATION_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# CENTRI_CONSOLIDATION_API_KEY=your-nebius-token-factory-key
# CENTRI_CONSOLIDATION_BATCH_SIZE=8

# --- Autonomy ---
CENTRI_AUTONOMY_LEVEL=autonomous_local
CENTRI_AUTO_COMMIT=true
CENTRI_AUTO_PUSH=false
